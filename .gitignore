# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
env/
.venv/
venv/
ENV/

# Local env/config
.env
.env.*
!.env.example

# Local data generated by the ingestion pipeline
data/serenity.sqlite
data/serenity.sqlite-*
data/raw/*.json
data/chat_monitor.json
export/

# Browser-copied X curl commands contain cookies/tokens
x_curl/*.curl

# Agent worktrees created by the harness
.claude/worktrees/

# Logs and OS/editor noise
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/

# Session cookies and browser profiles (NEVER commit)
x_curl/*
!x_curl/.gitkeep
data/browser_profile/
